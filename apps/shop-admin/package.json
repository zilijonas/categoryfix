{
  "name": "@categoryfix/shop-admin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Embedded Shopify admin app for CategoryFix phase 1.",
  "scripts": {
    "build": "react-router build",
    "dev": "shopify app dev",
    "lint": "pnpm typecheck",
    "start": "react-router-serve ./build/server/index.js",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "typecheck": "react-router typegen && tsc --noEmit",
    "worker": "node --experimental-strip-types ./worker.ts"
  },
  "dependencies": {
    "@categoryfix/db": "workspace:*",
    "@categoryfix/domain": "workspace:*",
    "@categoryfix/shopify-core": "workspace:*",
    "@react-router/dev": "^7.12.0",
    "@react-router/fs-routes": "^7.12.0",
    "@react-router/node": "^7.12.0",
    "@react-router/serve": "^7.12.0",
    "@shopify/app-bridge-react": "^4.2.4",
    "@shopify/shopify-app-react-router": "^1.1.0",
    "isbot": "^5.1.31",
    "openai": "^6.33.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.12.0",
    "vite-tsconfig-paths": "^5.1.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@prisma/client": "^6.19.2",
    "@shopify/polaris-types": "1.0.1",
    "@types/node": "^22.18.8",
    "@types/react": "^18.3.25",
    "@types/react-dom": "^18.3.7",
    "typescript": "^5.9.3",
    "vite": "^6.3.6",
    "vitest": "^2.1.9"
  }
}
