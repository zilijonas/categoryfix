---
import FeatureCard from "../components/FeatureCard.astro";
import PageHero from "../components/PageHero.astro";
import SectionShell from "../components/SectionShell.astro";
import MarketingLayout from "../layouts/MarketingLayout.astro";
import { primaryCtas, supportMailtoHref, withBase } from "../content/site.js";

const quickStart = [
  {
    title: "Run a Scan",
    body: "Start with a fresh scan so the review surface reflects current Shopify category state and the latest product signals.",
  },
  {
    title: "Review Findings by Status",
    body: "Accepted deterministic findings can be safer bulk candidates, while review-required and AI-assisted outcomes deserve closer inspection.",
  },
  {
    title: "Use Preview Counts Before Apply",
    body: "Preview counts make the upcoming change set explicit before a merchant confirms any category write.",
  },
  {
    title: "Keep Rollback in Mind",
    body: "After an apply job completes, rollback remains available when an approved category change needs to be reversed.",
  },
];
---

<MarketingLayout
  title="Docs"
  description="Merchant-facing guidance for CategoryFix scan, review, apply, rollback, and support expectations."
>
  <PageHero
    eyebrow="Merchant Docs"
    title="Start with the Workflow Merchants Actually Use."
    intro="This page stays product-facing on purpose. It explains what CategoryFix checks, how review and apply behave, and when to contact support during the closed beta."
    actions={[{ ...primaryCtas.viewWorkflow, href: withBase("/how-it-works") }, primaryCtas.contactSupport]}
  />

  <SectionShell
    eyebrow="Quick Start"
    title="What to Expect Inside the App"
    intro="These steps reflect the current merchant-facing workflow rather than a future-state product story."
  >
    <div class="card-grid card-grid-two">
      {quickStart.map((item) => (
        <FeatureCard title={item.title} body={item.body} tone="accent" />
      ))}
    </div>
  </SectionShell>

  <SectionShell
    eyebrow="Signals Used Today"
    title="What CategoryFix Evaluates for Deterministic Recommendations"
    intro="Recommendation quality starts with the inputs the product can actually inspect and explain."
    tone="tint"
  >
    <ul class="plain-list">
      <li>Product title.</li>
      <li>Product type.</li>
      <li>Vendor.</li>
      <li>Tags.</li>
      <li>Collections, when available.</li>
      <li>Current Shopify category state.</li>
    </ul>
  </SectionShell>

  <SectionShell
    eyebrow="Need Help?"
    title="Support Stays Simple During the Closed Beta."
    intro="Email-based support is intentional at this stage, and the shortest path is still the most effective one."
  >
    <div class="comparison-grid">
      <article class="comparison-card comparison-card-positive">
        <h3>Before You Escalate</h3>
        <ul class="bullet-list">
          <li>Review the finding status and basis facts.</li>
          <li>Check preview counts before applying a change set.</li>
          <li>Look for rollback options after completed apply jobs.</li>
        </ul>
      </article>
      <article class="comparison-card comparison-card-caution">
        <h3>When to Email Support</h3>
        <ul class="bullet-list">
          <li>Recommendation basis looks incomplete or unclear.</li>
          <li>Apply or rollback behavior needs investigation.</li>
          <li>Privacy, beta access, or operational timing questions come up.</li>
        </ul>
      </article>
    </div>

    <div class="action-group">
      <a class="button" href={withBase("/support")}>Open Support Guidance</a>
      <a class="button button-secondary" href={supportMailtoHref}>Email the Beta Team</a>
    </div>
  </SectionShell>
</MarketingLayout>
