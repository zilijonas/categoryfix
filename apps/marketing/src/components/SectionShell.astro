---
interface Props {
  id?: string;
  eyebrow?: string;
  title?: string;
  intro?: string;
  tone?: "default" | "plain" | "tint";
  className?: string;
}

const { id, eyebrow, title, intro, tone = "default", className } = Astro.props;
---

<section id={id} class:list={["section-shell", `section-shell-${tone}`, className]}>
  {eyebrow || title || intro ? (
    <div class="section-header">
      <div class="section-header-copy">
        {eyebrow ? <p class="eyebrow">{eyebrow}</p> : null}
        {title ? <h2>{title}</h2> : null}
        {intro ? <p>{intro}</p> : null}
      </div>
    </div>
  ) : null}

  <slot />
</section>
