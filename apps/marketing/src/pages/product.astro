---
import FeatureCard from "../components/FeatureCard.astro";
import PageHero from "../components/PageHero.astro";
import SectionShell from "../components/SectionShell.astro";
import MarketingLayout from "../layouts/MarketingLayout.astro";
import { primaryCtas, withBase } from "../content/site.js";

const capabilities = [
  {
    eyebrow: "Detect",
    title: "Find High-Signal Category Gaps",
    body: "CategoryFix evaluates title, product type, vendor, tags, collections, and current category state to flag products that look missing or mismatched.",
  },
  {
    eyebrow: "Review",
    title: "Inspect the Basis Behind Every Suggestion",
    body: "Recommendations remain explainable, with review surfaces that show the product facts and statuses behind the proposed change.",
  },
  {
    eyebrow: "Apply",
    title: "Approve Writes Only After an Explicit Decision",
    body: "Safe deterministic findings can move in bulk, while review-required and AI-assisted outcomes stay visibly distinct and intentionally chosen.",
  },
];

const safeguards = [
  {
    title: "Preview Before Write Is Mandatory",
    body: "Merchants see what will change before apply jobs run. CategoryFix does not silently update product categories in the background.",
  },
  {
    title: "No Certainty Theater",
    body: "The product avoids numeric confidence percentages and does not present heuristic or advisory output as guaranteed truth.",
  },
  {
    title: "AI Remains Secondary",
    body: "AI-assisted suggestions are optional fallback support for deterministic no-safe results and are excluded from default bulk apply selections.",
  },
  {
    title: "Rollback Is Not Hidden",
    body: "Undo remains part of the product, not a support-only rescue path, so change management stays visible after apply jobs complete.",
  },
];
---

<MarketingLayout
  title="Product"
  description="CategoryFix is a Shopify category review workflow focused on deterministic recommendations, preview-before-write safeguards, and rollback visibility."
>
  <PageHero
    eyebrow="Product Overview"
    title="CategoryFix Is a Review Workflow, Not a Black-Box Fixer."
    intro="The product helps Shopify teams detect category gaps, inspect evidence, and approve only the writes they actually want to send back to Shopify."
    supportingCopy="It is intentionally narrow: category correction with explainability, preview-before-write safeguards, and rollback at the center."
    actions={[primaryCtas.requestBeta, { ...primaryCtas.viewDocs, href: withBase("/docs") }]}
  />

  <SectionShell
    eyebrow="Current Capabilities"
    title="What the Current Product Already Supports"
    intro="The marketing surface stays aligned with implemented behavior rather than promising a broader automation platform."
  >
    <div class="card-grid card-grid-three">
      {capabilities.map((item) => (
        <FeatureCard eyebrow={item.eyebrow} title={item.title} body={item.body} tone="accent" />
      ))}
    </div>
  </SectionShell>

  <SectionShell
    eyebrow="Safeguards"
    title="Trust Rules Shape the Product Surface"
    intro="The same trust model appears in copy, layout, and interaction decisions across the marketing site."
    tone="tint"
  >
    <div class="card-grid card-grid-two">
      {safeguards.map((item) => (
        <FeatureCard title={item.title} body={item.body} />
      ))}
    </div>
  </SectionShell>

  <SectionShell
    eyebrow="Out of Scope in V1"
    title="What This Beta Does Not Claim"
    intro="Being explicit about what is out of scope keeps the product honest and reduces the risk of marketing drift."
  >
    <div class="comparison-grid">
      <article class="comparison-card comparison-card-positive">
        <h3>In Scope</h3>
        <ul class="bullet-list">
          <li>Deterministic recommendations with explanations.</li>
          <li>Optional AI-assisted fallback support for deterministic no-safe outcomes.</li>
          <li>Bulk review, safe bulk apply, rollback, and audit visibility.</li>
        </ul>
      </article>
      <article class="comparison-card comparison-card-caution">
        <h3>Out of Scope</h3>
        <ul class="bullet-list">
          <li>Merchant-facing Google category workflows.</li>
          <li>Billing automation and pricing flows.</li>
          <li>Feed-management platform claims beyond category correction.</li>
          <li>Fully autonomous AI categorization.</li>
        </ul>
      </article>
    </div>
  </SectionShell>
</MarketingLayout>
