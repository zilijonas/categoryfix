# Shared
NODE_ENV=development

# Shopify app
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=https://app.categoryfix.com
SHOPIFY_STAGING_APP_URL=https://staging-app.categoryfix.com
SHOPIFY_PRODUCTION_APP_URL=https://app.categoryfix.com
SHOPIFY_SCOPES=read_products,write_products
SHOPIFY_WEBHOOK_API_VERSION=2025-10

# Database
DATABASE_URL=

# Observability
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=

# Optional AI
CATEGORYFIX_AI_ENABLED=false
CATEGORYFIX_OPENAI_MODEL=
OPENAI_API_KEY=

# Marketing site
PUBLIC_SITE_URL=https://categoryfix.com

# Smoke tests
SMOKE_APP_URL=https://staging-app.categoryfix.com
SMOKE_PUBLIC_SITE_URL=https://categoryfix.com
