---
import FeatureCard from "../components/FeatureCard.astro";
import PageHero from "../components/PageHero.astro";
import SectionShell from "../components/SectionShell.astro";
import MarketingLayout from "../layouts/MarketingLayout.astro";
import { betaMailtoHref, primaryCtas, siteConfig, withBase } from "../content/site.js";

const betaChecklist = [
  "Your Shopify store or catalog context.",
  "Why category cleanup matters to your team right now.",
  "Whether deterministic review, rollback, or AI-assisted fallback support is the bigger need.",
  "Any timeline or operational constraints for the beta.",
];
---

<MarketingLayout
  title="Closed Beta"
  description="Request CategoryFix closed-beta access through the current email-based intake flow."
>
  <PageHero
    eyebrow="Closed Beta"
    title="Start with an Email, Not a Form Stack."
    intro={`Phase 8 keeps beta intake intentionally lightweight. There is no first-party signup backend here yet. If you want to evaluate CategoryFix, send a short note to ${siteConfig.supportEmail}.`}
    actions={[primaryCtas.requestBeta, { ...primaryCtas.viewDocs, href: withBase("/product") }]}
  />

  <SectionShell
    eyebrow="What to Include"
    title="Keep the Beta Conversation Grounded in the Current Product."
    intro="The best beta requests describe the real review workflow you need help with, not a hypothetical future-state platform."
  >
    <ul class="plain-list">
      {betaChecklist.map((item) => (
        <li>{item}</li>
      ))}
    </ul>
  </SectionShell>

  <SectionShell
    eyebrow="What Happens Next"
    title="Beta Intake Stays Human and Explicit."
    intro="A lightweight intake flow fits the product’s current trust posture better than a polished but misleading signup funnel."
    tone="tint"
  >
    <div class="card-grid card-grid-two">
      <FeatureCard
        title="Initial Fit Check"
        body="The first conversation verifies whether your store context matches the current closed-beta scope and operational readiness."
        tone="accent"
      />
      <FeatureCard
        title="Product Truth First"
        body="The response stays grounded in deterministic review, explicit apply, rollback visibility, and optional AI fallback support."
        tone="accent"
      />
    </div>

    <div class="action-group">
      <a class="button" href={betaMailtoHref}>Request Beta Access</a>
    </div>
  </SectionShell>
</MarketingLayout>
