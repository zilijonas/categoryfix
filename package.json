{
  "name": "categoryfix",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22.16.0",
    "pnpm": ">=10.32.1"
  },
  "scripts": {
    "build": "pnpm --filter @categoryfix/shop-admin build",
    "db:generate": "pnpm --filter @categoryfix/db prisma:generate",
    "db:migrate:deploy": "pnpm --filter @categoryfix/db prisma:migrate:deploy",
    "dev": "pnpm --filter @categoryfix/shop-admin dev",
    "verify:foundation": "node ./scripts/verify-foundation.mjs",
    "lint": "pnpm verify:foundation && pnpm --filter @categoryfix/shop-admin lint",
    "test": "pnpm verify:foundation && pnpm --filter @categoryfix/db prisma:generate && pnpm --filter @categoryfix/shop-admin test",
    "typecheck": "pnpm --filter @categoryfix/db prisma:generate && pnpm --filter @categoryfix/shop-admin typecheck"
  }
}
