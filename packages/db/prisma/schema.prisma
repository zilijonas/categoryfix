generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ShopInstallationState {
  INSTALLED
  UNINSTALLED
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?

  @@index([shop])
}

model ShopInstallation {
  id                   String                @id @default(cuid())
  shop                 String                @unique
  state                ShopInstallationState @default(INSTALLED)
  scopes               String?
  appUrl               String?
  offlineSessionId     String?               @unique
  accessTokenExpiresAt DateTime?
  installedAt          DateTime              @default(now())
  uninstalledAt        DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
}
