---
import FeatureCard from "../components/FeatureCard.astro";
import PageHero from "../components/PageHero.astro";
import SectionShell from "../components/SectionShell.astro";
import MarketingLayout from "../layouts/MarketingLayout.astro";
import { betaMailtoHref, primaryCtas, siteConfig, supportMailtoHref, withBase } from "../content/site.js";

const supportReasons = [
  {
    title: "Recommendation Questions",
    body: "Reach out when a recommendation basis looks incomplete, unclear, or mismatched with your catalog expectations.",
  },
  {
    title: "Apply or Rollback Follow-Up",
    body: "Contact support if an apply or rollback job needs review, especially when Shopify category state changed again after the original write.",
  },
  {
    title: "Privacy or Beta Access Requests",
    body: "Use the same email channel for privacy questions, support routing, and closed-beta access requests.",
  },
  {
    title: "Operational Constraints",
    body: "Share timing, catalog risk, or rollout concerns so the beta team can respond with the right context instead of generic advice.",
  },
];
---

<MarketingLayout
  title="Support"
  description="Support page for CategoryFix closed-beta merchants, with contact expectations and product guidance links."
>
  <PageHero
    eyebrow="Support"
    title="Support Starts with a Direct Email Channel During Beta."
    intro={`Closed-beta support is currently email-based. Reach the team at ${siteConfig.supportEmail} and include store context, scan or job identifiers when available, and a short description of what changed.`}
    actions={[primaryCtas.contactSupport, { ...primaryCtas.viewDocs, href: withBase("/docs") }]}
  />

  <SectionShell
    eyebrow="When to Contact Support"
    title="Use the Support Channel When the Workflow Needs a Human Check-In."
    intro="The goal is not to replace judgment. The goal is to make it clear when judgment should enter the flow."
  >
    <div class="support-grid">
      {supportReasons.map((item) => (
        <FeatureCard title={item.title} body={item.body} />
      ))}
    </div>
  </SectionShell>

  <SectionShell
    eyebrow="Helpful Links"
    title="Follow the Product Guidance Before Escalating."
    intro="These routes mirror the current beta support model and keep support conversations grounded in the product that exists today."
    tone="tint"
  >
    <div class="action-group">
      <a class="button" href={supportMailtoHref}>Email Support</a>
      <a class="button button-secondary" href={withBase("/docs")}>Read Merchant Docs</a>
      <a class="button button-secondary" href={withBase("/privacy")}>Review Privacy Summary</a>
      <a class="button button-ghost" href={betaMailtoHref}>Request Beta Access</a>
    </div>
  </SectionShell>
</MarketingLayout>
