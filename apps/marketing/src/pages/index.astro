---
import FeatureCard from "../components/FeatureCard.astro";
import MarketingIcon from "../components/MarketingIcon.astro";
import MetricStrip from "../components/MetricStrip.astro";
import PageHero from "../components/PageHero.astro";
import SectionShell from "../components/SectionShell.astro";
import WorkflowStep from "../components/WorkflowStep.astro";
import type { MarketingIconName } from "../lib/marketing-icons.js";
import MarketingLayout from "../layouts/MarketingLayout.astro";
import {
  homeMetrics,
  primaryCtas,
  siteConfig,
  trustGuardrails,
  trustPillars,
  withBase,
  workflowOverview,
} from "../content/site.js";

const pathActions = [
  {
    icon: "compass",
    title: "Product",
    body: "See the current beta scope, safeguards, and what CategoryFix intentionally does not claim.",
    href: withBase("/product"),
    hrefLabel: "Read the Product Story",
  },
  {
    icon: "book-open",
    title: "Docs",
    body: "Follow the merchant workflow for scan, review, apply, rollback, and support handoff.",
    href: withBase("/docs"),
    hrefLabel: "Open Merchant Docs",
  },
  {
    icon: "life-buoy",
    title: "Support",
    body: `Reach ${siteConfig.supportEmail} when a recommendation, apply job, or rollback flow needs a human check-in.`,
    href: withBase("/support"),
    hrefLabel: "Review Support Guidance",
  },
] satisfies {
  icon: MarketingIconName;
  title: string;
  body: string;
  href: string;
  hrefLabel: string;
}[];
---

<MarketingLayout
  title="Category Review That Stays Explainable"
  description="CategoryFix helps Shopify teams review category recommendations with clear reasons, explicit preview, and rollback-ready changes."
>
  <PageHero
    eyebrow="Trust-First Closed Beta"
    title="Review Shopify Category Recommendations Without Blind Automation."
    intro="CategoryFix helps merchandising teams spot missing or likely-wrong Shopify product categories, inspect the evidence behind every suggestion, and approve changes only when the review surface supports the decision."
    supportingCopy="Preview every category change before anything is written."
    actions={[primaryCtas.requestBeta, primaryCtas.viewWorkflow]}
    variant="home"
  >
    <div slot="aside" class="aside-stack home-hero-proof">
      <article>
        <div class="proof-card-title">
          <MarketingIcon name="shield-check" />
          <strong>Deterministic First</strong>
        </div>
        <p>
          Recommendations stay grounded in product fields and current category state rather than a
          hidden scoring model.
        </p>
      </article>
      <article>
        <div class="proof-card-title">
          <MarketingIcon name="sliders-horizontal" />
          <strong>Merchant Control</strong>
        </div>
        <p>
          Preview counts, basis facts, and explicit confirmation keep the approval loop visible from
          scan through apply.
        </p>
      </article>
      <article>
        <div class="proof-card-title">
          <MarketingIcon name="rotate-ccw" />
          <strong>Rollback Visibility</strong>
        </div>
        <p>Undo and rollback stay available after apply jobs complete.</p>
      </article>
    </div>
  </PageHero>

  <MetricStrip items={homeMetrics} />

  <SectionShell
    eyebrow="What the Beta Covers"
    title="Built for Careful Category Correction, Not Autopilot Merchandising."
    intro="The public site emphasizes the current product truth: deterministic recommendations, explainable review, explicit apply, and rollback-ready change management."
  >
    <div class="card-grid card-grid-three">
      {trustPillars.map((pillar) => (
        <FeatureCard
          eyebrow={pillar.eyebrow}
          icon={pillar.icon}
          title={pillar.title}
          body={pillar.body}
          tone="accent"
        />
      ))}
    </div>
  </SectionShell>

  <SectionShell
    eyebrow="Workflow Overview"
    title="Move from Scan to Rollback with the Same Trust Model End to End."
    intro="The product flow stays narrow on purpose so teams can evaluate category changes with context instead of relying on invisible automation."
    tone="tint"
  >
    <div class="workflow-grid">
      {workflowOverview.map((step) => (
        <WorkflowStep step={step.step} title={step.title} body={step.body} />
      ))}
    </div>
  </SectionShell>

  <SectionShell
    eyebrow="Where AI Fits"
    title="Optional AI Support Never Replaces the Review Surface."
    intro="AI only appears after deterministic logic cannot produce a safe recommendation, and the product still keeps merchant review in the loop."
  >
    <div class="comparison-grid">
      <article class="comparison-card comparison-card-positive">
        <div class="comparison-card-heading">
          <MarketingIcon name="shield-check" />
          <h3>What the Product Does</h3>
        </div>
        <ul class="status-list">
          {trustGuardrails.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </article>
      <article class="comparison-card comparison-card-caution">
        <div class="comparison-card-heading">
          <MarketingIcon name="sparkles" />
          <h3>What the Site Will Not Imply</h3>
        </div>
        <ul class="status-list">
          <li>No fully autonomous AI categorization claims.</li>
          <li>No certainty theater, no silent writes, and no “fixed it for you” language.</li>
          <li>No social-proof theater that pretends the closed beta already has broad public validation.</li>
        </ul>
      </article>
    </div>
  </SectionShell>

  <SectionShell
    eyebrow="Explore the Surface"
    title="Start with the Product Story, Then Move into Docs, Support, and Beta Intake."
    intro="Each route now follows the same design system, trust language, and action hierarchy."
  >
    <div class="card-grid card-grid-three">
      {pathActions.map((item) => (
        <FeatureCard
          icon={item.icon}
          title={item.title}
          body={item.body}
          href={item.href}
          hrefLabel={item.hrefLabel}
          tone="subtle"
        />
      ))}
    </div>
  </SectionShell>
</MarketingLayout>
