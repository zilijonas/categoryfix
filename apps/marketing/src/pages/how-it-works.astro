---
import FeatureCard from "../components/FeatureCard.astro";
import PageHero from "../components/PageHero.astro";
import SectionShell from "../components/SectionShell.astro";
import WorkflowStep from "../components/WorkflowStep.astro";
import MarketingLayout from "../layouts/MarketingLayout.astro";
import { primaryCtas, workflowOverview } from "../content/site.js";

const edgeCases = [
  {
    title: "No Safe Deterministic Recommendation",
    body: "The product can say exactly that and leave the product unchanged. It does not force a suggestion where the rules cannot defend one.",
  },
  {
    title: "Optional AI Fallback",
    body: "If AI assistance is enabled, it is used only as supporting context for deterministic no-safe results and never as silent platform truth.",
  },
  {
    title: "Stale Shopify State",
    body: "Apply and rollback flows stay honest about stale data, so teams can re-run a scan before retrying a write against changed category state.",
  },
];
---

<MarketingLayout
  title="How It Works"
  description="See how CategoryFix moves from scan to review, apply, and rollback without hiding uncertainty."
>
  <PageHero
    eyebrow="Workflow"
    title="Scan, Review, Apply, and Roll Back with the Same Trust Model."
    intro="CategoryFix is built around a simple rule: changes should stay explainable before they become scalable."
    supportingCopy="The workflow keeps that principle visible from the first scan through rollback."
    actions={[primaryCtas.requestBeta, primaryCtas.viewDocs]}
  />

  <SectionShell
    eyebrow="The Four-Step Loop"
    title="How Merchants Work with the Product Today"
    intro="Each step preserves the same information architecture: visible evidence, visible next actions, and visible recovery paths."
  >
    <div class="workflow-grid">
      {workflowOverview.map((step) => (
        <WorkflowStep step={step.step} title={step.title} body={step.body} />
      ))}
    </div>
  </SectionShell>

  <SectionShell
    eyebrow="Edge Cases"
    title="What Happens When the System Is Not Sure"
    intro="The product behaves conservatively when the recommendation surface needs more evidence or human judgment."
    tone="tint"
  >
    <div class="card-grid card-grid-three">
      {edgeCases.map((item) => (
        <FeatureCard title={item.title} body={item.body} />
      ))}
    </div>
  </SectionShell>
</MarketingLayout>
